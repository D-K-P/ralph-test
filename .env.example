# Trigger.dev Configuration
# Get your secret key from the Trigger.dev dashboard (Settings > API Keys)
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxx

# Public API key for frontend realtime subscriptions
TRIGGER_PUBLIC_API_KEY=tr_pub_xxxxxxxxxxxx

# Project reference (found in Project Settings)
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxx

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx
