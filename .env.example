# Trigger.dev Configuration
# Get your secret key from https://cloud.trigger.dev
# Found in your project settings under "API Keys"
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# Your Trigger.dev project ID
# Found in your project settings (starts with "proj_")
TRIGGER_PROJECT_ID=proj_your_project_id_here

# OpenAI API Key
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
