# Trigger.dev Secret Key - Get from https://cloud.trigger.dev dashboard
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# Trigger.dev Project Ref - Get from https://cloud.trigger.dev Project Settings page (format: proj_xxxxx)
TRIGGER_PROJECT_REF=proj_your_project_ref_here

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
