# Trigger.dev Configuration
# Get your secret key from https://cloud.trigger.dev
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# Project reference (found in Trigger.dev dashboard under Project Settings)
TRIGGER_PROJECT_REF=proj_your_project_ref_here

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
