# Trigger.dev Configuration
# Copy this file to .env.local and fill in your actual values

# Your Trigger.dev project ID
TRIGGER_PROJECT_ID=your_project_id_here

# Your Trigger.dev API key
TRIGGER_API_KEY=your_api_key_here

# Your Trigger.dev secret key for webhook authentication
TRIGGER_SECRET_KEY=your_secret_key_here

# Trigger.dev API URL (optional, defaults to https://api.trigger.dev)
TRIGGER_API_URL=https://api.trigger.dev