# Trigger.dev Configuration
# Get your secret key from https://cloud.trigger.dev
# Starts with tr_dev_ (development) or tr_prod_ (production)
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# Trigger.dev Project Reference
# Found in your project settings, starts with proj_
TRIGGER_PROJECT_REF=proj_your_project_ref_here

# OpenAI API Key
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
