# Trigger.dev Configuration
# Get your project ref from the Trigger.dev dashboard (starts with proj_)
TRIGGER_PROJECT_REF=proj_your_project_ref

# Your Trigger.dev secret key for backend authentication
# Found in Trigger.dev dashboard under API Keys
TRIGGER_SECRET_KEY=tr_dev_your_secret_key

# OpenAI API Key for AI functionality
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key
