# Trigger.dev Configuration
# Get your secret key from https://cloud.trigger.dev
TRIGGER_SECRET_KEY=your_trigger_secret_key_here

# Trigger.dev Project Configuration
TRIGGER_PROJECT_ID=your_project_id_here

# Trigger.dev Environment (dev, staging, prod)
TRIGGER_ENVIRONMENT=dev

# Optional: Trigger.dev API URL (defaults to cloud.trigger.dev)
# TRIGGER_API_URL=https://cloud.trigger.dev