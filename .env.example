# Trigger.dev Configuration
# Get your secret key from: https://cloud.trigger.dev -> Your Project -> API Keys
# Use tr_dev_xxx for development, tr_prod_xxx for production
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Trigger.dev Public API Key (optional - for frontend realtime without auth.createPublicToken)
# Get from: https://cloud.trigger.dev -> Your Project -> API Keys
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=tr_pub_your_public_key_here
